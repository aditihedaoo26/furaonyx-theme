<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ shop.name }} | Luxury Timepieces</title>
    {{ content_for_header }}
    
    <!-- CSS -->
    {{ 'styles.css' | asset_url | stylesheet_tag }}
    
    <!-- JS (Lenis from CDN for smooth scroll) -->
    <script src="https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.19/bundled/lenis.min.js"></script>
    <script src="{{ 'main.js' | asset_url }}" defer></script>
  </head>
  <body>
    <!-- Navigation -->
    <nav class="navbar">
      <a href="{{ routes.root_url }}" class="nav-brand">FURAONYX</a>
      <div class="nav-links">
        <a href="{{ routes.all_products_collection_url }}">Collection</a>
        <a href="{{ routes.root_url }}#story">Story</a>
        <a href="{{ routes.root_url }}#craft">Craft</a>
      </div>
      <a href="{{ routes.cart_url }}" class="nav-cart" id="cart-icon" onclick="openCartDrawer(); return false;">
        <svg viewBox="0 0 24 24">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
      </a>
    </nav>

    <!-- Content Layout -->
    <main id="MainContent" class="content-for-layout" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    <!-- Global Footer Section -->
    {% section 'footer' %}
    {% section 'cart-drawer' %}
  </body>
</html>
