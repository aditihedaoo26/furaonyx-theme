<section id="collection" class="products">
  <span class="hero-sub" style="font-size: 0.75rem; letter-spacing: 2px; text-align: center;">The Collection</span>
  <h2 class="section-title" style="margin-top: 1rem; margin-bottom: 3rem;">Timepieces of Intent</h2>

  <div class="product-grid">
    {% for product in collections['all'].products limit: 6 %}
    <div class="product-card">
      <a href="{{ product.url }}">
        <div class="product-image-wrapper" style="aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; overflow: hidden; background: transparent;">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | img_url: 'master' }}" alt="{{ product.featured_image.alt | escape }}" style="width: 100%; height: 100%; object-fit: contain; transition: transform 0.7s ease;">
          {% endif %}
        </div>
        <div class="product-info-wrap" style="padding: 2rem;">
            <p style="font-size: 0.75rem; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 0.5rem; letter-spacing: 2px;">Onyx Series</p>
            <h3 style="font-size: 1.4rem; margin-bottom: 0.5rem; font-family: var(--font-heading); color: var(--text-main); transition: color 0.3s ease;">
              {{ product.title }}
            </h3>
            <p style="color: var(--gold); margin-top: 0.5rem; font-family: var(--font-body); letter-spacing: 1px;">
              {{ product.price | money }}
            </p>
        </div>
      </a>
    </div>
    {% endfor %}
  </div>
</section>

<style>
.product-card:hover .product-image-wrapper img {
  transform: scale(1.05);
  border-color: rgba(201, 162, 74, 0.3);
}
</style>

{% schema %}
{
  "name": "Collection Grid",
  "settings": []
}
{% endschema %}
