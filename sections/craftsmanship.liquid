<section id="craft" class="craftsmanship">
  <div style="text-align: center; margin-bottom: 4rem;">
    <span class="hero-sub" style="font-size: 0.75rem; letter-spacing: 2px;">Craftsmanship</span>
    <h2 style="font-size: 3rem;">Built to Last. Designed to Impress.</h2>
  </div>
  <div class="craftsmanship-grid">
    <div class="craft-card">
      <div class="craft-icon">💎</div>
      <h3>316L Stainless Steel</h3>
      <p>Surgical-grade steel that resists corrosion and retains its brilliance.</p>
    </div>
    <div class="craft-card">
      <div class="craft-icon">⚙️</div>
      <h3>Precision Movement</h3>
      <p>Japanese & Miyota quartz movements built for lasting accuracy.</p>
    </div>
    <div class="craft-card">
      <div class="craft-icon">💧</div>
      <h3>Water Resistant</h3>
      <p>Engineered to withstand everyday encounters with water.</p>
    </div>
    <div class="craft-card">
      <div class="craft-icon">🛡️</div>
      <h3>1-Year Warranty</h3>
      <p>Every timepiece backed by our comprehensive manufacturer warranty.</p>
    </div>
    <div class="craft-card">
      <div class="craft-icon">📦</div>
      <h3>Premium Packaging</h3>
      <p>Presented in a handcrafted box worthy of the watch inside.</p>
    </div>
    <div class="craft-card">
      <div class="craft-icon">✓</div>
      <h3>Certified Quality</h3>
      <p>Every piece inspected through rigorous quality control standards.</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Craftsmanship",
  "settings": []
}
{% endschema %}
