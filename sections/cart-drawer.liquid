<div id="cart-overlay" onclick="closeCart()" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:8888;"></div>

<div id="cart-drawer" style="display:none;position:fixed;top:0;right:0;width:400px;height:100vh;background:#05070B;z-index:9999;padding:40px 30px;overflow-y:auto;border-left:1px solid #C9A24A;box-sizing:border-box;">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:30px;">
    <h2 style="color:#C9A24A;font-family:'Playfair Display',serif;margin:0;">Your Cart</h2>
    <button onclick="closeCart()" style="background:none;border:none;color:white;font-size:24px;cursor:pointer;">&times;</button>
  </div>
  <div id="cart-items" style="color:white;"></div>
  <div id="cart-footer" style="margin-top:30px;border-top:1px solid #333;padding-top:20px;"></div>
</div>

<script>
function openCart() {
  loadCart();
  document.getElementById('cart-drawer').style.display = 'block';
  document.getElementById('cart-overlay').style.display = 'block';
}

function closeCart() {
  document.getElementById('cart-drawer').style.display = 'none';
  document.getElementById('cart-overlay').style.display = 'none';
}

function loadCart() {
  fetch('/cart.js')
    .then(r => r.json())
    .then(cart => {
      let itemsHtml = '';
      if (cart.items.length === 0) {
        itemsHtml = '<p style="color:#999;">Your cart is empty</p>';
      } else {
        cart.items.forEach(item => {
          itemsHtml += `
            <div style="display:flex;gap:15px;margin-bottom:20px;padding-bottom:20px;border-bottom:1px solid #222;">
              <img src="${item.image}" style="width:80px;height:80px;object-fit:cover;">
              <div style="flex:1;">
                <p style="color:white;margin:0 0 5px;font-size:14px;">${item.title}</p>
                <p style="color:#C9A24A;margin:0;">₹${(item.price/100).toFixed(2)}</p>
                <div style="display:flex;align-items:center;gap:10px;margin-top:10px;">
                  <button onclick="updateQty('${item.key}', ${item.quantity-1})" style="background:#111;color:white;border:1px solid #333;width:28px;height:28px;cursor:pointer;">-</button>
                  <span style="color:white;">${item.quantity}</span>
                  <button onclick="updateQty('${item.key}', ${item.quantity+1})" style="background:#111;color:white;border:1px solid #333;width:28px;height:28px;cursor:pointer;">+</button>
                  <button onclick="updateQty('${item.key}', 0)" style="background:none;border:none;color:#666;cursor:pointer;font-size:12px;margin-left:auto;">Remove</button>
                </div>
              </div>
            </div>`;
        });
      }
      document.getElementById('cart-items').innerHTML = itemsHtml;
      document.getElementById('cart-footer').innerHTML = cart.items.length > 0 ? `
        <p style="color:white;display:flex;justify-content:space-between;"><span>Subtotal</span><span style="color:#C9A24A;">₹${(cart.total_price/100).toFixed(2)}</span></p>
        <p style="color:#888;font-size:12px;text-align:center;margin:10px 0;">🚚 FREE SHIPPING ACROSS INDIA</p>
        <a href="/checkout" style="display:block;background:#C9A24A;color:black;text-align:center;padding:16px;font-weight:bold;text-decoration:none;margin-top:10px;">CHECKOUT</a>
        <p onclick="closeCart()" style="color:#888;text-align:center;cursor:pointer;margin-top:15px;font-size:14px;">Continue Shopping</p>` : '';
    });
}

function updateQty(key, quantity) {
  fetch('/cart/change.js', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      id: key,
      quantity: quantity
    })
  })
  .then(r => r.json())
  .then(cart => {
    loadCart();
  });
}

document.addEventListener('submit', function(e) {
  if (e.target.matches('[action="/cart/add"]')) {
    e.preventDefault();
    const formData = new FormData(e.target);
    fetch('/cart/add.js', {
      method: 'POST',
      body: formData
    })
    .then(r => r.json())
    .then(data => {
      openCart();
    })
    .catch((error) => console.error('Error:', error));
  }
});

// In layout we had openCartDrawer, this is an alias to match navigation links
window.openCartDrawer = openCart;
window.closeCartDrawer = closeCart;
</script>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": []
}
{% endschema %}
